# Token du bot (Discord Developer Portal)
TOKEN=

# MongoDB Railway — variable fournie par le plugin / service Mongo sur Railway
MONGO_URL=

# Optionnel : même valeur que « Application ID » du portail. Si absent, déduit automatiquement du TOKEN.
DISCORD_CLIENT_ID=

# Optionnel : ID du serveur pour enregistrer les slash en dev (instantané). Si vide = commandes globales (peuvent mettre jusqu’à 1 h)
GUILD_ID=

# Railway injecte PORT pour les healthchecks — le bot écoute dessus et répond "ok"
PORT=3000
